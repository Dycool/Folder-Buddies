{
  "rules": {
    ".read": false,
    ".write": false,
    "webRooms": {
      "$room": {
        ".read": "$room.matches(/^[A-Za-z0-9_-]{2,16}$/)",
        ".write": "$room.matches(/^[A-Za-z0-9_-]{2,16}$/) && ((!data.exists() && newData.exists()) || (data.exists() && !newData.exists()))",
        "v": {
          ".validate": "newData.isNumber() && newData.val() === 1"
        },
        "host": {
          "createdAt": {
            ".validate": "newData.isNumber() && newData.val() > now - 86400000 && newData.val() <= now + 300000"
          },
          "$other": {
            ".validate": false
          }
        },
        "clients": {
          "$clientId": {
            ".validate": "$clientId.matches(/^[A-Za-z0-9_-]{8,80}$/)",
            "joinedAt": {
              ".validate": "newData.isNumber() && newData.val() > now - 86400000 && newData.val() <= now + 300000"
            },
            "$other": {
              ".validate": false
            },
            ".write": "$clientId.matches(/^[A-Za-z0-9_-]{8,80}$/) && ((!data.exists() && newData.exists()) || (data.exists() && !newData.exists()))"
          }
        },
        "signalsToHost": {
          "$msg": {
            "peerId": {
              ".validate": "newData.isString() && newData.val().length >= 8 && newData.val().length <= 80"
            },
            "ciphertext": {
              ".validate": "newData.isString() && newData.val().length >= 20 && newData.val().length <= 131072"
            },
            "at": {
              ".validate": "newData.isNumber() && newData.val() > now - 86400000 && newData.val() <= now + 300000"
            },
            "$other": {
              ".validate": false
            },
            ".write": "(!data.exists() && newData.exists()) || (data.exists() && !newData.exists())"
          }
        },
        "signalsToClient": {
          "$peerId": {
            ".validate": "$peerId.matches(/^[A-Za-z0-9_-]{8,80}$/)",
            "$msg": {
              "ciphertext": {
                ".validate": "newData.isString() && newData.val().length >= 20 && newData.val().length <= 131072"
              },
              "at": {
                ".validate": "newData.isNumber() && newData.val() > now - 86400000 && newData.val() <= now + 300000"
              },
              "$other": {
                ".validate": false
              },
              ".write": "(!data.exists() && newData.exists()) || (data.exists() && !newData.exists())"
            }
          }
        },
        "$other": {
          ".validate": false
        },
        ".validate": "newData.hasChildren(['v', 'host'])"
      }
    },
    "nativeRooms": {
      "$room": {
        ".read": "$room.matches(/^[A-Za-z0-9_-]{2,16}$/)",
        ".write": "$room.matches(/^[A-Za-z0-9_-]{2,16}$/) && ((!data.exists() && newData.exists()) || (data.exists() && !newData.exists()))",
        "v": {
          ".validate": "newData.isNumber() && newData.val() === 1"
        },
        "lookup": {
          ".validate": "newData.isString() && newData.val().length === 2"
        },
        "salt": {
          ".validate": "newData.isString() && newData.val().length >= 4 && newData.val().length <= 8192"
        },
        "wrapped": {
          ".validate": "newData.isString() && newData.val().length >= 4 && newData.val().length <= 8192"
        },
        "payload": {
          ".validate": "newData.isString() && newData.val().length >= 4 && newData.val().length <= 8192"
        },
        "owner": {
          ".validate": "newData.isString() && newData.val().length >= 16 && newData.val().length <= 8192"
        },
        "createdAt": {
          ".validate": "newData.isNumber() && newData.val() * 1000 > now - 2592000000 && newData.val() * 1000 <= now + 300000"
        },
        "$other": {
          ".validate": false
        },
        ".validate": "newData.hasChildren(['v', 'lookup', 'salt', 'wrapped', 'payload', 'owner', 'createdAt'])"
      }
    }
  }
}